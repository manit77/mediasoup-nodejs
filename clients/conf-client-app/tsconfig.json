{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    /* The 2026 Standard for Vite/React 19 */
    "moduleResolution": "bundler", 
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    
    /* Strictness - Transitioning from false to true is recommended for Video apps */
    "strict": false, 
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,

    "baseUrl": ".",
    "paths": {
      "@client/*": ["src/*"],
      "@conf-client/*": ["../../conf/conf-client/src/*"],
      "@rooms-client/*": ["../../rooms/rooms-client/src/*"],
      "@websocket-client/*": ["../../libs/websocket-client/src/*"],
      "@webrtc-client/*": ["../../libs/webrtc-client/src/*"],
      "@conf-models/*": ["../../conf/conf-models/src/*"],
      "@rooms-models/*": ["../../rooms/rooms-models/src/*"]
    }
  },
  "include": [
    "src",
    "src/vite-env.d.ts",
    "../../conf/*/src",
    "../../rooms/*/src",
    "../../libs/*/src"
  ]
}